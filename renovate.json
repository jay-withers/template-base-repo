  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "schedule:weekly"],
  "autoApprove": true,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "pre-commit": {
    "fileMatch": ["(^|/)\\.pre-commit-config\\.yaml$"]
  }
}
